<idea-plugin>
    <depends>com.intellij.modules.platform</depends>

    <description><![CDATA[
        Authoring support for OpenFastTrace specification documents and coverage tags.
    ]]></description>

    <extensions defaultExtensionNs="com.intellij">
        <!-- [impl->dsn~live-template-integration~1] -->
        <!-- [impl->dsn~show-oft-live-templates-in-live-template-settings~1] -->
        <defaultLiveTemplates file="/liveTemplates/OpenFastTrace.xml"/>
        <fileBasedIndex implementation="org.itsallcode.openfasttrace.intellijplugin.indexing.OftSpecificationIndex"/>
        <gotoSymbolContributor implementation="org.itsallcode.openfasttrace.intellijplugin.navigation.OftChooseByNameContributor"/>
        <gotoDeclarationHandler implementation="org.itsallcode.openfasttrace.intellijplugin.navigation.OftGotoDeclarationHandler"/>
        <definitionsScopedSearch implementation="org.itsallcode.openfasttrace.intellijplugin.navigation.OftDefinitionsScopedSearch"/>
        <completion.contributor
                language="Markdown"
                implementationClass="org.itsallcode.openfasttrace.intellijplugin.navigation.OftSpecificationCompletionProvider"/>
        <completion.contributor
                language="TEXT"
                implementationClass="org.itsallcode.openfasttrace.intellijplugin.navigation.OftSpecificationCompletionProvider"/>
        <psi.referenceContributor
                implementation="org.itsallcode.openfasttrace.intellijplugin.navigation.OftSpecificationReferenceContributor"/>
        <psi.referenceContributor
                language="JAVA"
                implementation="org.itsallcode.openfasttrace.intellijplugin.navigation.OftCoverageTagReferenceContributor"/>
        <psi.referenceContributor
                language="Markdown"
                implementation="org.itsallcode.openfasttrace.intellijplugin.navigation.OftCoverageTagReferenceContributor"/>
        <psi.referenceContributor
                language="TEXT"
                implementation="org.itsallcode.openfasttrace.intellijplugin.navigation.OftCoverageTagReferenceContributor"/>
        <highlightingPassFactory implementation="org.itsallcode.openfasttrace.intellijplugin.highlighting.OftHighlightingPassRegistrar"/>
        <projectConfigurable
                parentId="tools"
                instance="org.itsallcode.openfasttrace.intellijplugin.trace.OftTraceProjectConfigurable"
                id="org.itsallcode.openfasttrace.intellijplugin.trace.OftTraceProjectConfigurable"
                displayName="OpenFastTrace"
                nonDefaultProject="true"/>
    </extensions>

    <actions>
        <group
                id="Oft.ToolsMenu"
                text="OpenFastTrace"
                popup="true"
                description="OpenFastTrace project actions.">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
            <action
                    id="Oft.TraceProject.ToolsMenu"
                    class="org.itsallcode.openfasttrace.intellijplugin.trace.OftTraceProjectAction"
                    text="Trace Project"
                    description="Run an OpenFastTrace trace for the current project and show the text output.">
                <keyboard-shortcut keymap="$default" first-keystroke="ctrl alt shift O"/>
            </action>
        </group>
        <action
                id="Oft.OpenUserGuide.HelpMenu"
                class="org.itsallcode.openfasttrace.intellijplugin.help.OpenFastTraceUserGuideAction"
                text="OpenFastTrace User Guide"
                description="Open the OpenFastTrace user guide in the integrated browser tab.">
            <add-to-group group-id="HelpMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
